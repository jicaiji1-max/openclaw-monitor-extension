{
  "manifest_version": 3,
  "name": "Sessions Monitor",
  "version": "1.0.4",
  "description": "在 Agent 页面上显示 Session 状态监控面板",
  "host_permissions": ["http://127.0.0.1:*/*"],
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}